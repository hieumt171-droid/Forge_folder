{
	"name": "@atlaskit/react-ufo",
	"version": "6.7.5",
	"description": "Parts of React UFO that are publicly available",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlassian/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"singleton": true,
		"team": "UIP Frontend Observability"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"typesVersions": {
		">=4.5 <4.9": {
			"*": [
				"dist/types-ts4.5/*",
				"dist/types-ts4.5/index.d.ts"
			]
		}
	},
	"sideEffects": false,
	"atlaskit:src": "src/index.ts",
	"dependencies": {
		"@atlaskit/atlassian-context": "^0.11.0",
		"@atlaskit/browser-apis": "^0.0.2",
		"@atlaskit/feature-gate-js-client": "^5.8.0",
		"@atlaskit/interaction-context": "^3.1.0",
		"@atlaskit/platform-feature-flags": "^1.1.0",
		"@babel/runtime": "^7.0.0",
		"@opentelemetry/api": "^1.9.0",
		"bind-event-listener": "^3.0.0",
		"bowser-ultralight": "^1.0.6",
		"scheduler": "0.23.2",
		"uuid": "^3.1.0"
	},
	"peerDependencies": {
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@af/integration-testing": "workspace:^",
		"@atlassian/a11y-jest-testing": "^0.12.0",
		"@atlassian/feature-flags-test-utils": "^1.1.0",
		"@atlassian/react-compiler-gating": "workspace:^",
		"@atlassian/testing-library": "^0.6.0",
		"@testing-library/react": "^16.3.0",
		"@types/is-ci": "^3.0.0",
		"@types/scheduler": "0.23.0",
		"is-ci": "^3.0.1",
		"react": "^18.2.0"
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": [
				"atlassian-conventions"
			],
			"circular-dependencies": [
				"file-and-folder-level"
			]
		},
		"@repo/internal": {
			"dom-events": "use-bind-event-listener",
			"analytics": [
				"analytics-next"
			],
			"design-tokens": [
				"color"
			],
			"theming": [
				"react-context"
			],
			"ui-components": [
				"lite-mode"
			],
			"deprecation": [
				"no-deprecated-imports"
			],
			"styling": [
				"static",
				"emotion"
			],
			"imports": [
				"import-no-extraneous-disable-for-examples-and-docs"
			]
		}
	},
	"platform-feature-flags": {
		"platform_ufo_canvas_heatmap_full_precision": {
			"type": "boolean"
		},
		"platform_ufo_remove_deprecated_config_fields": {
			"type": "boolean"
		},
		"platform_ufo_detect_entrypoint_parent": {
			"type": "boolean"
		},
		"ufo_payload_use_idle_callback": {
			"type": "boolean"
		},
		"platform_ufo_assets_check_for_nan": {
			"type": "boolean"
		},
		"platform_ufo_data-is-hovered-v4-exclusion": {
			"type": "boolean"
		},
		"platform_ufo_critical_metrics_payload": {
			"type": "boolean"
		},
		"ufo_detect_aborting_interaction_during_ssr": {
			"type": "boolean"
		},
		"ufo_fix_aborting_interaction_detection_during_ssr": {
			"type": "boolean"
		},
		"platform_ufo_segment_critical_metrics": {
			"type": "boolean"
		},
		"platform_ufo_add_segments_count_threshold": {
			"type": "boolean"
		},
		"platform_ufo_exclude_3p_extensions_from_ttvc": {
			"type": "boolean"
		},
		"platform_ufo_filter_cls_logs_same_rects_positions": {
			"type": "boolean"
		},
		"media-perf-uplift-mutation-fix": {
			"type": "boolean"
		},
		"platform_ufo_use_native_page_visibility_api": {
			"type": "boolean"
		},
		"platform_mark_ufo_segment_first_load": {
			"type": "boolean"
