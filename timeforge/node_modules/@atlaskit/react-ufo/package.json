		"platform_ufo_disable_ufo_names_config": {
			"type": "boolean"
		},
		"platform_ufo_exclude_dark_reader_extension": {
			"type": "boolean"
		},
		"platform_ufo_exclude_fdprocessedid_attribute": {
			"type": "boolean"
		},
		"platform_ufo_labelstack_dedup": {
			"type": "boolean"
		},
		"platform_ufo_trim_labelstack_trailing_slashes": {
			"type": "boolean"
		},
		"ufo_disable_ttvc_v4": {
			"type": "boolean"
		},
		"platform_ufo_3p_segment_timings": {
			"type": "boolean"
		},
		"platform_ufo_metric_variants": {
			"type": "boolean"
		},
		"platform_ufo_exclude_pdnd_attributes_from_vc": {
			"type": "boolean"
		},
		"platform_ufo_terminal_errors_track_client_errors": {
			"type": "boolean"
		},
		"ufo-bump-walk-levels": {
			"type": "boolean"
		},
		"platform_ufo_ecosystem_data_in_payload": {
			"type": "boolean"
		},
		"platform_ufo_always_emit_raw_handler": {
			"type": "boolean"
		},
		"platform_ufo_compress_resource_timings": {
			"type": "boolean"
		},
		"platform_ufo_exclude_gql_timings_from_length_trim": {
			"type": "boolean"
