		"platform_ufo_keypress_interaction_abort": {
			"type": "boolean"
		},
		"platform_ufo_enable_otel_context_manager": {
			"type": "boolean"
		},
		"platform_reset_post_interaction_on_new_interaction": {
			"type": "boolean"
		},
		"platform_enable_better_page_visibility": {
			"type": "boolean"
		},
		"ufo_remove_featureflags_from_trimmed_fields": {
			"type": "boolean"
		},
		"ufo_vc_revision_trim_enabled": {
			"type": "boolean"
