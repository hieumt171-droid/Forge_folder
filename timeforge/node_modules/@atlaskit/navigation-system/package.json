{
	"name": "@atlaskit/navigation-system",
	"version": "9.4.3",
	"description": "The latest navigation system for Atlassian apps.",
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"typesVersions": {
		">=4.5 <4.9": {
			"*": [
				"dist/types-ts4.5/*",
				"dist/types-ts4.5/index.d.ts"
			]
		}
	},
	"sideEffects": [
		"*.compiled.css"
	],
	"atlaskit:src": "src/index.tsx",
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlassian/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "ADS: nav4",
		"website": {
			"name": "Navigation system",
			"category": "Navigation",
			"subPages": [
				{
					"title": "Layout",
					"id": "layout",
					"sortKey": 1
				},
				{
					"title": "Side nav items",
					"id": "side-nav-items",
					"sortKey": 2
				},
				{
					"title": "Top nav items",
					"id": "top-nav-items",
					"sortKey": 3
				}
			]
		},
		"integrationTests": {
			"additionalBrowsers": [
				"desktop-firefox",
				"desktop-webkit"
			]
		}
	},
	"dependencies": {
		"@atlaskit/analytics-next": "^11.3.0",
		"@atlaskit/app-provider": "^4.3.0",
		"@atlaskit/avatar": "^25.15.0",
		"@atlaskit/button": "^23.11.0",
		"@atlaskit/css": "^0.19.0",
		"@atlaskit/ds-lib": "^7.0.0",
		"@atlaskit/icon": "^35.4.0",
		"@atlaskit/layering": "^3.8.0",
		"@atlaskit/logo": "^20.2.0",
		"@atlaskit/platform-feature-flags": "^1.1.0",
		"@atlaskit/platform-feature-flags-react": "^0.5.0",
		"@atlaskit/popup": "^4.24.0",
		"@atlaskit/pragmatic-drag-and-drop": "^1.8.0",
		"@atlaskit/primitives": "^19.0.0",
		"@atlaskit/side-nav-items": "^1.14.0",
		"@atlaskit/tokens": "^13.3.0",
		"@atlaskit/tooltip": "^22.6.0",
		"@atlaskit/visually-hidden": "^3.1.0",
		"@babel/runtime": "^7.0.0",
		"@compiled/react": "^0.20.0",
		"bind-event-listener": "^3.0.0",
		"raf-schd": "^4.0.3",
		"tiny-invariant": "^1.2.0"
	},
	"peerDependencies": {
		"react": "^18.2.0",
		"react-dom": "^18.2.0"
	},
	"devDependencies": {
		"@af/accessibility-testing": "workspace:^",
		"@af/integration-testing": "workspace:^",
		"@af/visual-regression": "workspace:^",
		"@atlaskit/badge": "^18.7.0",
		"@atlaskit/banner": "^14.1.0",
		"@atlaskit/breadcrumbs": "^16.1.0",
		"@atlaskit/dropdown-menu": "^16.10.0",
		"@atlaskit/flag": "^17.13.0",
		"@atlaskit/form": "^15.5.0",
		"@atlaskit/heading": "^5.4.0",
		"@atlaskit/inline-dialog": "^18.1.0",
		"@atlaskit/link": "^3.4.0",
		"@atlaskit/lozenge": "^13.8.0",
		"@atlaskit/menu": "^8.5.0",
		"@atlaskit/modal-dialog": "^15.2.0",
		"@atlaskit/onboarding": "^14.6.0",
		"@atlaskit/page-header": "^12.2.0",
		"@atlaskit/page-layout": "^4.3.0",
		"@atlaskit/popper": "^7.2.0",
		"@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^2.1.0",
		"@atlaskit/select": "^21.12.0",
		"@atlaskit/skeleton": "^2.1.0",
		"@atlaskit/spotlight": "^0.15.0",
		"@atlaskit/textfield": "^8.3.0",
		"@atlaskit/top-layer": "^0.16.0",
		"@atlassian/feature-flags-test-utils": "^1.1.0",
		"@atlassian/gemini": "^1.46.0",
		"@atlassian/react-compiler-gating": "workspace:^",
		"@atlassian/search-dialog": "^10.3.0",
		"@atlassian/ssr-tests": "workspace:^",
		"@atlassian/test-utils": "^1.0.0",
		"@atlassian/testing-library": "^0.6.0",
		"@axe-core/playwright": "^4.11.1",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.4.3",
		"raf-stub": "^2.0.1",
		"react": "^18.2.0",
		"react-dom": "^18.2.0"
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": "atlassian-conventions"
		},
		"@repo/internal": {
			"dom-events": "use-bind-event-listener",
			"design-tokens": [
				"color",
				"spacing"
			],
			"deprecation": "no-deprecated-imports",
			"imports": [
				"import-no-extraneous-disable-for-examples-and-docs"
			],
			"styling": [
				"emotion"
			]
		}
	},
	"platform-feature-flags": {
		"platform-dst-top-layer": {
			"type": "boolean",
			"referenceOnly": true
		},
		"platform-component-visual-refresh": {
			"type": "boolean",
			"referenceOnly": true
		},
		"navx-full-height-sidebar": {
			"type": "boolean"
		},
		"platform_dst_button_chevron_sizing": {
			"type": "boolean"
		},
		"platform-dst-shape-theme-default": {
			"type": "boolean"
		},
		"platform_dst_nav4_custom_theming_fhs_1": {
			"type": "boolean"
		},
		"platform_dst_nav4_skip_link_a11y_1": {
			"type": "boolean"
		}
	},
	"homepage": "https://atlassian.design/components/navigation-system"
}
