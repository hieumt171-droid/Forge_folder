{
	"name": "@atlaskit/forge-react-types",
	"version": "1.7.1",
	"description": "Component types for Forge UI Kit React components",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-monorepo",
	"author": "Atlassian Pty Ltd",
	"types": "dist/types/index.d.ts",
	"typesVersions": {
		">=4.5 <4.9": {
			"global": [
				"dist/types-ts4.5/components/global/__generated__/index.d.ts"
			],
			"*": [
				"dist/types-ts4.5/*",
				"dist/types-ts4.5/index.d.ts"
			]
		}
	},
	"atlaskit:src": "src/index.ts",
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlassian/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Forge UI"
	},
	"dependencies": {
		"@atlaskit/banner": "^14.1.0",
		"@atlaskit/blanket": "^15.0.0",
		"@atlaskit/breadcrumbs": "^16.1.0",
		"@atlaskit/button": "^23.11.0",
		"@atlaskit/comment": "^13.3.0",
		"@atlaskit/datetime-picker": "^17.9.0",
		"@atlaskit/dynamic-table": "^18.4.0",
		"@atlaskit/form": "^15.5.0",
		"@atlaskit/inline-edit": "^15.6.0",
		"@atlaskit/modal-dialog": "^15.2.0",
		"@atlaskit/navigation-system": "^9.4.0",
		"@atlaskit/object": "^1.0.0",
		"@atlaskit/pagination": "^16.3.0",
		"@atlaskit/popup": "^4.23.0",
		"@atlaskit/primitives": "^19.0.0",
		"@atlaskit/progress-bar": "^4.2.0",
		"@atlaskit/progress-tracker": "^10.5.0",
		"@atlaskit/radio": "^8.6.0",
		"@atlaskit/section-message": "^8.13.0",
		"@atlaskit/select": "^21.12.0",
		"@atlaskit/skeleton": "^2.1.0",
		"@atlaskit/spinner": "^19.1.0",
		"@atlaskit/tabs": "^19.1.0",
		"@atlaskit/tag": "^14.15.0",
		"@atlaskit/tag-group": "^12.1.0",
		"@atlaskit/textarea": "^8.3.0",
		"@atlaskit/textfield": "^8.3.0",
		"@atlaskit/tile": "^1.1.0",
		"@atlaskit/toggle": "^16.1.0",
		"@atlaskit/tokens": "^13.3.0",
		"@atlaskit/tooltip": "^22.6.0",
		"@babel/runtime": "^7.0.0",
		"@emotion/react": "^11.7.1",
		"@emotion/serialize": "^1.1.0"
	},
	"peerDependencies": {
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@atlassian/codegen": "^0.2.0",
		"@atlassian/forge-ui": "^36.18.0",
		"@atlassian/react-compiler-gating": "workspace:^",
		"@types/node": "^24.0.0",
		"lodash": "^4.17.21",
		"react": "^18.2.0",
		"ts-morph": "^17.0.0",
		"ts-node": "^10.9.1",
		"typescript": "5.9.2"
	},
	"scripts": {
		"codegen": "ts-node ./scripts/codegen-runner.ts",
		"codegen-global": "ts-node ./scripts/codegen-global-runner.ts",
		"check-types": "ts-node --type-check ./scripts/typechecker.ts"
	},
	"sideEffects": [
		"*.compiled.css"
	],
	"platform-feature-flags": {}
}
